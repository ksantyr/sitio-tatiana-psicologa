---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mensaje enviado — Tatiana Isaza" description="Tu mensaje fue recibido correctamente.">
  <section class="min-h-[80vh] flex items-center justify-center bg-gradient-to-br from-bg to-bg-soft px-6">
    <div class="text-center max-w-md">

      <!-- Ícono -->
      <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="font-heading text-3xl text-text mb-4">
        ¡Mensaje enviado!
      </h1>

      <p class="font-body text-text-muted leading-relaxed mb-8">
        Gracias por escribirme. Me pondré en contacto contigo en un plazo de 24 horas.
      </p>

      <a
        href="/"
        class="inline-block bg-primary text-white font-body text-sm px-8 py-3 rounded-full hover:bg-primary-dark transition-colors duration-200"
      >
        Volver al inicio
      </a>

    </div>
  </section>
</Layout>
