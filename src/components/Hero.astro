---
---

<section id="inicio" class="min-h-[90vh] flex items-center bg-gradient-to-br from-bg to-bg-soft">
  <div class="w-full max-w-5xl mx-auto px-6 py-12 md:py-24 grid md:grid-cols-2 gap-10 items-center">

    <!-- Texto -->
    <div class="order-2 md:order-1 min-w-0 w-full overflow-hidden">
      <span class="inline-block font-body text-xs text-primary tracking-[0.25em] uppercase mb-5">
        Psicóloga Clínica
      </span>

      <h1 class="font-heading text-3xl md:text-5xl lg:text-[3.25rem] text-text leading-tight mb-6">
        Un espacio seguro
        <em class="text-primary not-italic block">para observarte y transformar.</em>
      </h1>

      <p class="font-body text-text-muted text-lg leading-relaxed mb-10 md:max-w-md">
        Soy Tatiana Isaza, psicóloga. Te acompaño en tu proceso hacia el bienestar
        con empatía, respeto, cuidado y profesionalismo.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="#contacto"
          class="bg-primary text-white font-body text-sm px-7 py-3 rounded-full hover:bg-primary-dark transition-colors duration-200"
        >
          Agenda tu cita
        </a>
        <a
          href="#servicios"
          class="border border-primary text-primary font-body text-sm px-7 py-3 rounded-full hover:bg-bg-soft transition-colors duration-200"
        >
          Mis servicios
        </a>
      </div>
    </div>

    <!-- Foto -->
    <div class="order-1 md:order-2 flex justify-center">
      <div class="relative w-52 h-60 md:w-80 md:h-[26rem]">

        <!-- Forma decorativa detrás -->
        <div class="absolute inset-0 bg-primary-light/40 rounded-[60%_40%_40%_60%/60%_60%_40%_40%] -rotate-6 scale-105"></div>

        <!-- Contenedor de imagen con forma orgánica -->
        <div class="absolute inset-0 overflow-hidden rounded-[60%_40%_40%_60%/60%_60%_40%_40%] bg-gradient-to-b from-primary-light/50 to-primary/30">
          <!-- Reemplazar con <img> cuando esté la foto real -->
          <div class="w-full h-full flex items-end justify-center">
            <svg viewBox="0 0 200 220" xmlns="http://www.w3.org/2000/svg" class="w-48 opacity-40">
              <ellipse cx="100" cy="72" rx="42" ry="46" fill="currentColor" class="text-primary-dark"/>
              <path d="M20 200 Q20 140 100 140 Q180 140 180 200 Z" fill="currentColor" class="text-primary-dark"/>
            </svg>
          </div>
        </div>

        <!-- Círculos decorativos -->
        <div class="absolute -bottom-5 -right-5 w-20 h-20 bg-accent/40 rounded-full -z-10"></div>
        <div class="absolute -top-5 -left-5 w-14 h-14 bg-primary-light/60 rounded-full -z-10"></div>
      </div>
    </div>

  </div>
</section>
