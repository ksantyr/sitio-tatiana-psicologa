---
const año = new Date().getFullYear();

const navLinks = [
  { label: 'Inicio',    href: '#inicio' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Contacto',  href: '#contacto' },
];

const INSTAGRAM = 'https://www.instagram.com/tatianaisazapsi?igsh=MWZvMDF2YjBndXNiNw==';
const TIKTOK    = 'https://vt.tiktok.com/ZSQTyvDhV/';
const WHATSAPP  = '573228716838';
---

<footer class="bg-text py-14">
  <div class="max-w-5xl mx-auto px-6">

    <div class="grid sm:grid-cols-3 gap-10 mb-10">

      <!-- Marca -->
      <div>
        <p class="font-heading text-xl text-bg font-semibold mb-1">Tatiana Isaza</p>
        <p class="font-body text-xs text-bg/50 uppercase tracking-[0.2em] mb-4">Psicóloga</p>
        <p class="font-body text-sm text-bg/60 leading-relaxed">
          Acompañamiento psicológico profesional con empatía y compromiso.
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <p class="font-body text-xs text-bg/40 uppercase tracking-widest mb-4">Secciones</p>
        <ul class="space-y-2">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="font-body text-sm text-bg/70 hover:text-bg transition-colors duration-200">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto rápido -->
      <div>
        <p class="font-body text-xs text-bg/40 uppercase tracking-widest mb-4">Contacto</p>
        <div class="space-y-3">
          <a
            href={`https://wa.me/${WHATSAPP}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 font-body text-sm text-bg/70 hover:text-bg transition-colors duration-200"
          >
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.933 1.395 5.61L0 24l6.555-1.368A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.371l-.36-.214-3.888.811.826-3.783-.236-.387A9.818 9.818 0 1112 21.818z"/>
            </svg>
            WhatsApp
          </a>

          <a
            href={INSTAGRAM}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 font-body text-sm text-bg/70 hover:text-bg transition-colors duration-200"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>

          <a
            href={TIKTOK}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 font-body text-sm text-bg/70 hover:text-bg transition-colors duration-200"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
            </svg>
            TikTok
          </a>
        </div>
      </div>

    </div>

    <!-- Línea divisoria -->
    <div class="border-t border-bg/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-body text-xs text-bg/40">
        © {año} Tatiana Isaza · Psicóloga. Todos los derechos reservados.
      </p>
      <p class="font-body text-xs text-bg/30">
        Información confidencial · Uso exclusivo para pacientes
      </p>
    </div>

  </div>
</footer>
