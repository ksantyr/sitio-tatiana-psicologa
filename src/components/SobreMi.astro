---
const formacion = [
  'Psicología — Universidad de Antioquia',
  'Diplomado en suicidología — Colegio Colombiano de Psicólogos',
];

const modalidades = [
  'Terapia Cognitivo-Conductual',
  'Terapia Individual',
  'Terapia en Línea',
];
---

<section id="sobre-mi" class="py-16 md:py-24 bg-bg-soft">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">

    <!-- Foto -->
    <div class="flex justify-center">
      <div class="relative w-48 h-56 md:w-64 md:h-[22rem]">

        <!-- Forma decorativa detrás (invertida respecto al Hero) -->
        <div class="absolute inset-0 bg-accent/30 rounded-[40%_60%_60%_40%/40%_40%_60%_60%] rotate-6 scale-105"></div>

        <!-- Contenedor de imagen -->
        <div class="absolute inset-0 overflow-hidden rounded-[40%_60%_60%_40%/40%_40%_60%_60%] bg-gradient-to-b from-accent-light/60 to-primary-light/40">
          <img
            src="/images/Tati_sobre_mi.JPG"
            alt="Tatiana Isaza en consulta"
            class="w-full h-full object-cover object-top"
          />
        </div>

        <!-- Círculos decorativos -->
        <div class="absolute -top-4 -right-4 w-16 h-16 bg-primary-light/50 rounded-full -z-10"></div>
        <div class="absolute -bottom-4 -left-4 w-12 h-12 bg-accent/40 rounded-full -z-10"></div>
      </div>
    </div>

    <!-- Texto -->
    <div class="min-w-0">
      <span class="inline-block font-body text-xs text-primary tracking-[0.25em] uppercase mb-4">
        Sobre mí
      </span>

      <h2 class="font-heading text-3xl md:text-4xl text-text leading-snug mb-6">
        Conoce a tu psicóloga
      </h2>

      <p class="font-body text-text-muted leading-relaxed mb-8">
        He acompañado a +100 pacientes en su proceso individual. Mi trabajo se dirige
        al entendimiento profundo de tu experiencia para generar cambios reales y
        sostenibles por medio de la construcción de herramientas y la gestión emocional.
      </p>

      <!-- Formación -->
      <div class="mb-8">
        <h3 class="font-heading text-lg text-primary-dark mb-4">Formación</h3>
        <ul class="space-y-3">
          {formacion.map(item => (
            <li class="flex items-start gap-3 font-body text-sm text-text-muted">
              <span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Enfoque terapéutico -->
      <div>
        <h3 class="font-heading text-lg text-primary-dark mb-4">Enfoque terapéutico</h3>
        <p class="font-body text-sm text-text-muted leading-relaxed mb-5">
          Trabajo desde el enfoque cognitivo conductual, explorando la relación entre
          tus emociones, tu cognición y tu conducta para identificar tus necesidades particulares.
        </p>

        <!-- Etiquetas de modalidades -->
        <div class="flex flex-wrap gap-2">
          {modalidades.map(tag => (
            <span class="font-body text-xs text-primary-dark bg-primary-light/30 border border-primary-light px-3 py-1.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
