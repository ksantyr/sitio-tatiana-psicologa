---
import { servicios } from '../data/servicios.js';

const iconos = {
  online: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />
  </svg>`,
};

const servicio = servicios[0];
---

<section id="servicios" class="py-16 md:py-24 bg-bg">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Encabezado -->
    <div class="text-center mb-12">
      <span class="inline-block font-body text-xs text-primary tracking-[0.25em] uppercase mb-4">
        ¿En qué te puedo ayudar?
      </span>
      <h2 class="font-heading text-3xl md:text-4xl text-text leading-snug">
        Mi servicio
      </h2>
      <div class="mt-4 mx-auto w-12 h-0.5 bg-accent rounded-full"></div>
    </div>

    <!-- Tarjeta única -->
    <div class="bg-bg-soft border border-primary-light/20 rounded-2xl p-8 md:p-10">

      <!-- Ícono + título -->
      <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 bg-primary/10 text-primary rounded-xl flex items-center justify-center flex-shrink-0">
          <div class="w-7 h-7" set:html={iconos[servicio.icon]} />
        </div>
        <h3 class="font-heading text-2xl md:text-3xl text-text">
          {servicio.titulo}
        </h3>
      </div>

      <!-- Descripción -->
      <p class="font-body text-text-muted leading-relaxed mb-8">
        {servicio.descripcion}
      </p>

      <!-- Temas -->
      <div>
        <p class="font-body text-xs text-primary-dark font-semibold uppercase tracking-widest mb-4">
          Ideal para trabajar:
        </p>
        <div class="flex flex-wrap gap-2">
          {servicio.temas.map(tema => (
            <span class="font-body text-sm text-text-muted bg-bg border border-primary-light/30 px-4 py-1.5 rounded-full">
              {tema}
            </span>
          ))}
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a
        href="/#contacto"
        class="inline-block bg-primary text-white font-body text-sm px-8 py-3 rounded-full hover:bg-primary-dark transition-colors duration-200"
      >
        Agenda tu sesión
      </a>
    </div>

  </div>
</section>
